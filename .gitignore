# StadiumIQ .gitignore

# Operating System files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# Editor/IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
npm-debug.log*

# Temporary files
*.tmp
*.bak

# Environment files (never commit API keys!)
.env
.env.local
.env.*.local

# Node (if tools used locally)
node_modules/
package-lock.json
yarn.lock

# Build outputs (if added later)
dist/
build/

# OS-specific
$RECYCLE.BIN/
